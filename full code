import csv
import json
import os
import pickle
import sys
import time
from dataclasses import dataclass
from enum import Enum


class PaymentMethod(Enum):
    CARD = "Card"
    CASH = "Cash"
    PAYPAL = "Paypal"


@dataclass
class ProductData:
    name: str
    price: float
    stock: int


class Product:
    def __init__(self, data: ProductData):
        if data.price < 0:
            raise ValueError("Price cannot be negative")
        if data.stock < 0:
            raise ValueError("Stock cannot be negative")
        self._data = data

    @property
    def name(self): return self._data.name

    @property
    def price(self): return self._data.price

    @price.setter
    def price(self, value):
        if value < 0:
            raise ValueError("Price cannot be negative")
        self._data.price = value

    @property
    def stock(self): return self._data.stock

    @stock.setter
    def stock(self, value):
        if value < 0:
            raise ValueError("Stock cannot be negative")
        self._data.stock = value

    def __str__(self):
        return f"Product: {self.name} | Price: {self.price} USD | Stock: {self.stock} pcs"

    def __repr__(self):
        return f"Product(name='{self.name}', price={self.price})"

    def __add__(self, other):
        if isinstance(other, (int, float)):
            return Product(ProductData(self.name, self.price + other, self.stock))
        raise TypeError("Support only numeric addition")

    def __lt__(self, other):
        if not isinstance(other, Product): return NotImplemented
        return self.price < other.price

    def get_final_price(self):
        return self.price


class DigitalProduct(Product):
    def __init__(self, data: ProductData, size):
        super().__init__(data)
        self.size = size

    def get_final_price(self):
        return self.price * 0.9  # 10% discount for digital items


class PhysicalProduct(Product):
    def __init__(self, data: ProductData, weight, shipping_cost):
        super().__init__(data)
        self.weight = weight
        self.shipping_cost = shipping_cost

    def get_final_price(self):
        return self.price + self.shipping_cost


class TaxCalculator:
    def __init__(self, tax_rate: float):
        self.tax_rate = tax_rate
        self.calculations_count = 0
        self.total_tax_accumulated = 0.0

    def __call__(self, price: float) -> float:
        self.calculations_count += 1
        calculated_tax = price * self.tax_rate
        self.total_tax_accumulated += calculated_tax
        return calculated_tax


class PhysicalProductIterator:
    def __init__(self, items_list):
        self.items_list = items_list
        self.index = 0

    def __iter__(self):
        return self

    def __next__(self):
        while self.index < len(self.items_list):
            product, qty = self.items_list[self.index]
            self.index += 1
            if isinstance(product, PhysicalProduct):
                return product, qty
        raise StopIteration


class ShoppingCart:
    def __init__(self):
        self.items = []
        self.tax_calculator = TaxCalculator(0.20)
        self.config = {"store_name": "Default Store", "max_items_limit": 999}

    def add(self, product: Product, qty: int):
        max_limit = self.config.get("max_items_limit", 999)
        current_total = sum(q for _, q in self.items)
        
        if current_total + qty > max_limit:
            print(f"[Warning] System restriction! Cannot add {qty} items. Cart limit: {max_limit}")
            return

        if qty > product.stock:
            raise ValueError(f"Not enough stock available. Available: {product.stock} pcs")
        self.items.append((product, qty))

    def __len__(self):
        return len(self.items)

    def __iter__(self):
        return iter(sorted(self.items, key=lambda x: x[0].price))

    def get_physical_products(self):
        return PhysicalProductIterator(self.items)

    def load_config(self, filepath="config.json"):
        current_dir = os.path.dirname(os.path.abspath(__file__))
        full_path = os.path.join(current_dir, filepath)
        try:
            with open(full_path, 'r', encoding='utf-8') as f:
                self.config = json.load(f)
            print(f"[System] Configuration from JSON loaded successfully.")
            print(f" -> Store Name: {self.config.get('store_name')}")
            print(f" -> System Cart Limit: {self.config.get('max_items_limit')} items")
        except FileNotFoundError:
            print("[Warning] config.json not found. Using default internal settings.")

    def save_system_state(self, filepath="system_backup.pkl"):
        current_dir = os.path.dirname(os.path.abspath(__file__))
        full_path = os.path.join(current_dir, filepath)
        with open(full_path, 'wb') as f:
            pickle.dump(self.items, f)
        print("[System] Full cart state serialized to Pickle (Auto-save executed).")

    def load_system_state(self, filepath="system_backup.pkl"):
        current_dir = os.path.dirname(os.path.abspath(__file__))
        full_path = os.path.join(current_dir, filepath)
        try:
            with open(full_path, 'rb') as f:
                self.items = pickle.load(f)
            print(f"[System] State restored successfully. Items in cart: {len(self.items)}")
        except FileNotFoundError:
            print("[System] Backup file not found. Starting with an empty cart.")

    def export_sales_report(self, filepath="sales_report.csv"):
        current_dir = os.path.dirname(os.path.abspath(__file__))
        full_path = os.path.join(current_dir, filepath)
        with open(full_path, 'w', newline='', encoding='utf-8') as f:
            writer = csv.writer(f, delimiter=',')
            writer.writerow(["Product Name", "Product Type", "Quantity", "Base Price", "Final Price"])
            for prod, qty in self.items:
                prod_type = "Digital" if isinstance(prod, DigitalProduct) else "Physical"
                writer.writerow([prod.name, prod_type, qty, prod.price, prod.get_final_price()])
        print(f"[System] Sales report exported to CSV file: {full_path}")


class Checkout:
    def __init__(self, cart: ShoppingCart):
        self.cart = cart
        self.start_time = None

    def __enter__(self):
        self.start_time = time.time()
        for p, q in self.cart.items:
            if p.stock < q:
                raise ValueError(f"Product '{p.name}' ran out of stock during checkout transaction!")
            p.stock -= q
        print("[Checkout] Products successfully reserved in stock.")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        duration = time.time() - self.start_time
        if duration > 15:
            print(f"[Timeout] Session expired ({duration:.1f}s). Transaction aborted.")
            for p, q in self.cart.items:
                p.stock += q
            return False
        if exc_type:
            for p, q in self.cart.items:
                p.stock += q
            print(f"[Checkout] Payment failed ({exc_val}). Stock holdings restored.")
            return True  # Suppress exception to keep the CLI interactive menu alive
        else:
            print("[Checkout] Payment success! Order processing completed.")
        return False


def show_menu():
    print("\n" + "="*45)
    print("         E-COMMERCE MAIN MENU")
    print("="*45)
    print("1. Display current shopping cart items")
    print("2. Add new product to cart")
    print("3. Process order checkout (Checkout)")
    print("4. Save system state manually")
    print("5. Export tabular report to CSV")
    print("0. Exit application")
    print("="*45)


# --- CLI ENTRY POINT ---
if __name__ == "__main__":
    cart = ShoppingCart()
    
    # System Initialization
    cart.load_config()
    cart.load_system_state()
    
    print("\nWelcome to E-commerce Shopping Cart System v1.0")
    
    while True:
        show_menu()
        try:
            choice = input("Select an option: ").strip()
            
            match choice:
                case "1":
                    if not cart.items:
                        print("[Info] Your shopping cart is empty.")
                    else:
                        print("\n--- SHOPPING CART ITEMS (Sorted by Price) ---")
                        for idx, (prod, qty) in enumerate(cart, 1):
                            total_item_price = prod.get_final_price() * qty
                            print(f"{idx}. {prod} | Ordered: {qty} pcs | Total Price: {total_item_price} USD")
                
                case "2":
                    print("\nSelect product type: 1 - Digital, 2 - Physical")
                    p_type = input("Your choice: ").strip()
                    if p_type not in ["1", "2"]:
                        raise ValueError("Invalid product type selection. Must be 1 or 2.")
                    
                    name = input("Product name: ").strip()
                    if not name:
                        raise ValueError("Product name cannot be empty.")
                        
                    price = float(input("Base product price (USD): "))
                    stock = int(input("Available stock quantity: "))
                    data = ProductData(name, price, stock)
                    
                    if p_type == "1":
                        size = float(input("File size (MB): "))
                        product = DigitalProduct(data, size)
                    else:
                        weight = float(input("Product weight (kg): "))
                        shipping = float(input("Shipping cost: "))
                        product = PhysicalProduct(data, weight, shipping)
                        
                    qty = int(input("How many items to add to cart?: "))
                    cart.add(product, qty)
                    print(f"[Success] Product '{name}' added to your cart.")
                
                case "3":
                    if not cart.items:
                        print("[Warning] Cannot checkout an empty shopping cart.")
                        continue
                        
                    cart_total = sum(p.get_final_price() * q for p, q in cart.items)
                    print(f"\nTotal amount due: {cart_total} USD")
                    print("Available payment methods:")
                    for method in PaymentMethod:
                        print(f" - {method.value}")
                        
                    with Checkout(cart):
                        confirm = input("Type 'pay' to confirm your payment transaction: ").strip()
                        if confirm.lower() != "pay":
                            raise Exception("Payment cancelled or rejected by user request.")
                
                case "4":
                    cart.save_system_state()
                
                case "5":
                    cart.export_sales_report()
                    
                case "0":
                    print("\nShutting down system. Executing final auto-save...")
                    cart.save_system_state()
                    print("Thank you for using our service. Goodbye!")
                    sys.exit(0)
                    
                case _:
                    print("[Warning] Unknown option! Please select a valid number from 0 to 5.")
                    
        except ValueError as e:
            print(f"\n⚠️ [Data Input Error]: {e}")
            print("Please try again and ensure correct numeric formats are provided.")
        except Exception as e:
            print(f"\n❌ [Runtime Interface Error]: {e}")
            print("System stabilized. Returning to safety main menu loop.")
